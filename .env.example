# StyleShift AI (HaircutApp) Environment Variables Template
# Copy this file to .env and fill in the values.

# App Behavior Toggle
VITE_USE_MOCK_FIREBASE=true
VITE_USE_FIREBASE_EMULATORS=false

# Firebase Configuration (Example/Public Values)
VITE_FIREBASE_API_KEY=local-emulator-api-key
VITE_FIREBASE_AUTH_DOMAIN=styleshift.local
VITE_FIREBASE_PROJECT_ID=styleshift-local
VITE_FIREBASE_STORAGE_BUCKET=styleshift-local.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000
VITE_FIREBASE_APP_ID=local-app-id
