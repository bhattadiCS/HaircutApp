rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userPayloadMatches(userId) {
      return !("uid" in request.resource.data) || request.resource.data.uid == userId;
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && userPayloadMatches(userId);
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && userPayloadMatches(userId);
      allow delete: if isOwner(userId);

      match /history/{historyId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}